    <string name="presentation_batch_g_beta_sheet_welcome_title">Selamat datang di PixelPlayer 0.6.0-beta</string>
    <string name="presentation_batch_g_beta_sheet_welcome_body">Beta ini sekarang difokuskan pada stabilitas, performa, dan pemutaran lintas perangkat sambil merilis integrasi baru yang besar.</string>
