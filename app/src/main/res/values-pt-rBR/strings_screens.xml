    <!-- Word delimiter config -->
    <string name="word_delimiter_section_title">Delimitadores de Palavra Atuais</string>
    <string name="word_delimiter_section_subtitle">Estas palavras-chave dividem nomes de artistas quando cercadas por espaços. Corresponde sem diferenciar maiúsculas/minúsculas. Toque para remover.</string>
    <string name="word_delimiter_empty">Nenhum delimitador de palavra configurado</string>
    <string name="word_delimiter_add_title">Adicionar Novo Delimitador de Palavra</string>
    <string name="word_delimiter_hint">ex., feat. ou ft.</string>
    <string name="word_delimiter_help_title">Como os Delimitadores de Palavra Funcionam</string>
    <string name="word_delimiter_help_body">Os delimitadores de palavra são correspondidos sem diferenciar maiúsculas/minúsculas com espaços ao redor.\n\nDelimitadores de um único caractere (como \"x\") exigem espaços em ambos os lados para evitar correspondências falsas.\n\nExemplos:\n  \"Drake feat. Rihanna\" -&gt; Drake, Rihanna\n  \"Marshmello x Bastille\" -&gt; Marshmello, Bastille\n  \"A vs. B\" -&gt; A, B</string>
    <string name="word_delimiters_screen_title">Delimitadores de Palavra</string>
    <string name="word_delimiter_reset_title">Redefinir Delimitadores de Palavra?</string>
