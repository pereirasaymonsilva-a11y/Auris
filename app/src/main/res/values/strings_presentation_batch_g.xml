    <string name="presentation_batch_g_beta_sheet_welcome_title">Welcome to Auris 1.0.0</string>
    <string name="presentation_batch_g_beta_sheet_welcome_body">This is the initial beta version of Auris. This version is still under development; therefore, you may encounter unwanted bugs. If you find them, report them so we can fix them as soon as possible.</string>
    <string name="presentation_batch_g_beta_sheet_expect_title">What to expect</string>
    <string name="presentation_batch_g_beta_sheet_expect_1">Faster daily use: smoother startup, navigation, and player interactions throughout the app.</string>
    <string name="presentation_batch_g_beta_sheet_expect_2">Wider device support: Android Auto, Wear OS updates, and greater Cast reliability.</string>
